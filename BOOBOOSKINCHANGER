-- MODULES
-- ═══════════════════════════════════════════════

local function robust_require(module)
    local ok, result = pcall(require, module)

    if ok then
        return result
    end

    for _, v in pairs(getgc(true)) do
        if type(v) == "table" then
            if tostring(module):find("CosmeticLibrary") and v.Cosmetics then
                return v
            end

            if tostring(module):find("ClientViewModel") and v.GetWrap then
                return v
            end
        end
    end

    return nil
end

local CosmeticLibrary
local ReplicatedClass
local ClientViewModel

task.spawn(function()
    CosmeticLibrary = robust_require(
        ReplicatedStorage.Modules:WaitForChild("CosmeticLibrary")
    )

    ReplicatedClass = robust_require(
        ReplicatedStorage.Modules:WaitForChild("ReplicatedClass")
    )

    local Modules = player.PlayerScripts.Modules

    ClientViewModel = robust_require(
        Modules.ClientReplicatedClasses.ClientFighter.ClientItem.ClientViewModel
    )

    if not CosmeticLibrary or not ClientViewModel then
        warn("Failed loading modules")
        return
    end

    local function getCosmeticData(name, cType)
        local base = CosmeticLibrary.Cosmetics[name]

        if not base then
            return nil
        end

        local data = table.clone(base)
        data.Name = name
        data.Type = cType

        return data
    end

    --// WRAP HOOK
    local oldGetWrap = ClientViewModel.GetWrap

    ClientViewModel.GetWrap = function(self)
        local weapon = self.ClientItem and self.ClientItem.Name

        if weapon and _G.EquippedData[weapon] then
            local wrap = _G.EquippedData[weapon].Wrap

            if wrap ~= "None" then
                return getCosmeticData(wrap, "Wrap")
            end
        end

        return oldGetWrap(self)
    end

    --// SKIN HOOK
    local oldNew = ClientViewModel.new

    ClientViewModel.new = function(replicatedData, clientItem)
        pcall(function()
            local weapon = clientItem.Name

            if not weapon then
                return
            end

            local skin = _G.EquippedData[weapon].Skin

            if skin and skin ~= "Default" then
                local cosData = getCosmeticData(skin, "Skin")

                if cosData then
                    local dataKey = ReplicatedClass:ToEnum("Data")
                    local skinKey = ReplicatedClass:ToEnum("Skin")
                    local nameKey = ReplicatedClass:ToEnum("Name")

                    replicatedData[dataKey] = replicatedData[dataKey] or {}
                    replicatedData[dataKey][skinKey] = cosData
                    replicatedData[dataKey][nameKey] = skin
                end
            end
        end)

        local vm = oldNew(replicatedData, clientItem)

        task.delay(0.1, function()
            pcall(function()
                if vm and vm._UpdateWrap then
                    vm:_UpdateWrap()
                end
            end)
        end)

        return vm
    end
end)

