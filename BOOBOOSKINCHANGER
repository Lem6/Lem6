local weaponNames = {}

for weapon in pairs(SkinLists) do
    table.insert(weaponNames, weapon)
end

-- Sort alphabetically

table.sort(weaponNames)

-- Create one weapon every frame

task.spawn(function()
    for _, weapon in ipairs(weaponNames) do
        local skins = SkinLists[weapon]

        local Section = MainTab:Section({
            Title = weapon
        })

        Section:Dropdown({
            Title = "Skin",
            Values = skins,
            Default = _G.EquippedData[weapon].Skin,
            Callback = function(value)
                _G.EquippedData[weapon].Skin = value

                pcall(function()
                    CosmeticLibrary.Equip(weapon, "Skin", value)
                end)
            end
        })

        Section:Dropdown({
            Title = "Wrap",
            Values = WrapList,
            Default = _G.EquippedData[weapon].Wrap,
            Callback = function(value)
                _G.EquippedData[weapon].Wrap = value
            end
        })

        --// IMPORTANT
        task.wait()
    end
end)

