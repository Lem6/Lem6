-- Rivals Skin Changer | WindUI Local Script
-- Place inside: Players > LocalPlayer > PlayerScripts

local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

local Players       = game:GetService("Players")
local LocalPlayer   = Players.LocalPlayer
local ViewModels    = LocalPlayer.PlayerScripts.Assets.ViewModels
local WeaponsFolder = ViewModels.Weapons

-- all skin cases (everything except Weapons folder)
local function getSkinCases()
    local list = {}
    for _, child in ipairs(ViewModels:GetChildren()) do
        if child.Name ~= "Weapons" then
            table.insert(list, child.Name)
        end
    end
    table.sort(list)
    return list
end

-- all skins inside a case (just all children, no name matching)
local function getSkinsInCase(caseName)
    local list = {}
    local caseFolder = ViewModels:FindFirstChild(caseName)
    if not caseFolder then return list end
    for _, child in ipairs(caseFolder:GetChildren()) do
        table.insert(list, child.Name)
    end
    table.sort(list)
    return list
end

-- weapons you own
local function getOwnedWeapons()
    local list = {}
    for _, w in ipairs(WeaponsFolder:GetChildren()) do
        table.insert(list, w.Name)
    end
    table.sort(list)
    return list
end

-- apply: clone chosen skin into chosen weapon
local function applySkin(caseName, skinName, weaponName)
    local skinObj   = ViewModels:FindFirstChild(caseName) and ViewModels[caseName]:FindFirstChild(skinName)
    local weaponObj = WeaponsFolder:FindFirstChild(weaponName)
    if not skinObj or not weaponObj then return false end
    weaponObj:ClearAllChildren()
    for _, v in pairs(skinObj:GetChildren()) do
        v:Clone().Parent = weaponObj
    end
    return true
end

-- ─── UI ───────────────────────────────────────────────────────────────────────
local Window = WindUI:CreateWindow({
    Title = "Rivals Skin Changer",
    Icon = "shirt",
    Author = "by Lem6",
    Folder = "RivalsSkinChanger",
    Size = UDim2.fromOffset(580, 460),
    ToggleKey = Enum.KeyCode.RightShift,
    Transparent = true,
    Theme = "Dark",
    Resizable = true,
})

local Tab = Window:Tab({ Title = "Skins", Icon = "layers" })

local selectedCase   = nil
local selectedSkin   = nil
local selectedWeapon = nil

local skinCases    = getSkinCases()
local ownedWeapons = getOwnedWeapons()

local SkinDropdown -- forward declare

-- 1. Pick skin case
local CaseDropdown = Tab:Dropdown({
    Title = "Skin Case",
    Desc = "Pick a skin case",
    Values = skinCases,
    Value = skinCases[1] or "None",
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedCase = option
        selectedSkin = nil
        -- show ALL skins inside this case
        local skins = getSkinsInCase(option)
        if #skins == 0 then skins = {"(empty case)"} end
        SkinDropdown:Refresh(skins)
        SkinDropdown:Select(skins[1])
        selectedSkin = skins[1]
    end,
})
selectedCase = skinCases[1]

-- 2. Pick skin (ALL items inside the case, no filtering)
local initialSkins = getSkinsInCase(selectedCase or "")
if #initialSkins == 0 then initialSkins = {"(empty case)"} end

SkinDropdown = Tab:Dropdown({
    Title = "Skin",
    Desc = "All skins inside the selected case",
    Values = initialSkins,
    Value = initialSkins[1],
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedSkin = option
    end,
})
selectedSkin = initialSkins[1]

-- 3. Pick YOUR weapon to apply it to
local WeaponDropdown = Tab:Dropdown({
    Title = "Your Weapon",
    Desc = "Which weapon to apply the skin to",
    Values = ownedWeapons,
    Value = ownedWeapons[1] or "None",
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedWeapon = option
    end,
})
selectedWeapon = ownedWeapons[1]

-- Apply
Tab:Button({
    Title = "Apply Skin",
    Desc = "Clones selected skin into your selected weapon",
    Callback = function()
        if not selectedCase or not selectedSkin or not selectedWeapon then
            WindUI:Notification({ Title = "Skin Changer", Desc = "Fill in all 3 dropdowns first!", Icon = "alert-circle", Time = 3 })
            return
        end
        if applySkin(selectedCase, selectedSkin, selectedWeapon) then
            WindUI:Notification({ Title = "Skin Changer", Desc = selectedSkin .. " → " .. selectedWeapon .. " done!", Icon = "check-circle", Time = 3 })
        else
            WindUI:Notification({ Title = "Skin Changer", Desc = "Failed — check skin/weapon names.", Icon = "x-circle", Time = 3 })
        end
    end,
})

Tab:Divider()

Tab:Button({
    Title = "Refresh",
    Desc = "Re-scans ViewModels",
    Callback = function()
        skinCases = getSkinCases()
        ownedWeapons = getOwnedWeapons()
        CaseDropdown:Refresh(skinCases)
        WeaponDropdown:Refresh(ownedWeapons)
        WindUI:Notification({ Title = "Skin Changer", Desc = "Refreshed!", Icon = "refresh-cw", Time = 3 })
    end,
})

WindUI:Notification({
    Title = "Skin Changer Loaded",
    Desc = "RightShift to toggle. " .. #ownedWeapons .. " weapon(s) owned.",
    Icon = "shirt",
    Time = 5,
})
