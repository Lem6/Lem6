-- Rivals Skin Changer | WindUI Local Script
-- Place inside: Players > LocalPlayer > PlayerScripts

local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ─── References ───────────────────────────────────────────────────────────────
local Players    = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ViewModels  = LocalPlayer.PlayerScripts.Assets.ViewModels
local WeaponsFolder = ViewModels.Weapons  -- ViewModels.Weapons["Battle Axe"] etc.

-- ─── Helper: get all Skin Case folder names ───────────────────────────────────
local function getSkinCases()
    local cases = {}
    for _, child in ipairs(ViewModels:GetChildren()) do
        if child.Name ~= "Weapons" then  -- skip the real weapons folder
            table.insert(cases, child.Name)
        end
    end
    table.sort(cases)
    return cases
end

-- ─── Helper: get all weapon names from a given skin case ─────────────────────
local function getWeaponsInCase(caseName)
    local caseFolder = ViewModels:FindFirstChild(caseName)
    if not caseFolder then return {} end
    local weapons = {}
    for _, child in ipairs(caseFolder:GetChildren()) do
        table.insert(weapons, child.Name)
    end
    table.sort(weapons)
    return weapons
end

-- ─── Core: apply one skin weapon → real weapon ────────────────────────────────
-- skin  = ViewModels["Skin Case 2"]["Ban Axe"]
-- weapon = ViewModels.Weapons["Battle Axe"]  (same weapon, different name possible)
local function applyOneSkin(skinWeaponObj, realWeaponObj)
    if not skinWeaponObj or not realWeaponObj then return end
    realWeaponObj:ClearAllChildren()
    for _, v in pairs(skinWeaponObj:GetChildren()) do
        v:Clone().Parent = realWeaponObj
    end
end

-- ─── Apply ALL weapons inside a skin case ─────────────────────────────────────
-- Matches by name: skin case weapon name must match real weapon name
local function applyAllInCase(caseName)
    local caseFolder = ViewModels:FindFirstChild(caseName)
    if not caseFolder then return 0 end

    local count = 0
    for _, skinWeapon in pairs(caseFolder:GetChildren()) do
        local realWeapon = WeaponsFolder:FindFirstChild(skinWeapon.Name)
        if realWeapon then
            applyOneSkin(skinWeapon, realWeapon)
            count += 1
        end
    end
    return count
end

-- ─── Build UI ─────────────────────────────────────────────────────────────────
local Window = WindUI:CreateWindow({
    Title = "Rivals Skin Changer",
    Icon = "shirt",
    Author = "by Lem6",
    Folder = "RivalsSkinChanger",
    Size = UDim2.fromOffset(580, 460),
    ToggleKey = Enum.KeyCode.RightShift,
    Transparent = true,
    Theme = "Dark",
    Resizable = true,
})

local Tab = Window:Tab({
    Title = "Skins",
    Icon = "layers",
})

-- ─── State ────────────────────────────────────────────────────────────────────
local selectedCase   = nil
local selectedWeapon = nil  -- "All" or a specific weapon name

local skinCases = getSkinCases()

-- ─── Skin Case Dropdown ───────────────────────────────────────────────────────
local CaseDropdown = Tab:Dropdown({
    Title = "Skin Case",
    Desc = "Select which skin case to pull from (e.g. Skin Case 2)",
    Values = skinCases,
    Value = skinCases[1] or "None",
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedCase = option
        -- refresh weapon list for this case
        local weapons = getWeaponsInCase(option)
        table.insert(weapons, 1, "All Weapons")
        WeaponDropdown:Refresh(weapons)
        WeaponDropdown:Select("All Weapons")
        selectedWeapon = "All Weapons"
    end,
})

if skinCases[1] then
    selectedCase = skinCases[1]
end

-- ─── Weapon Dropdown ──────────────────────────────────────────────────────────
local initialWeapons = getWeaponsInCase(selectedCase or "")
table.insert(initialWeapons, 1, "All Weapons")

local WeaponDropdown = Tab:Dropdown({
    Title = "Weapon",
    Desc = "Choose a specific weapon or apply all at once",
    Values = initialWeapons,
    Value = "All Weapons",
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedWeapon = option
    end,
})
selectedWeapon = "All Weapons"

-- ─── Apply Button ─────────────────────────────────────────────────────────────
Tab:Button({
    Title = "Apply Skin",
    Desc = "Clones skin children into the real weapon(s) in Weapons folder",
    Callback = function()
        if not selectedCase then
            WindUI:Notification({ Title = "Skin Changer", Desc = "Select a skin case first!", Icon = "alert-circle", Time = 3 })
            return
        end

        if selectedWeapon == "All Weapons" then
            -- Apply all weapons in this skin case
            local count = applyAllInCase(selectedCase)
            WindUI:Notification({
                Title = "Skin Changer",
                Desc = "Applied " .. selectedCase .. " to " .. count .. " weapon(s)!",
                Icon = "check-circle",
                Time = 4,
            })
        else
            -- Apply just one weapon
            local caseFolder = ViewModels:FindFirstChild(selectedCase)
            local skinWeapon = caseFolder and caseFolder:FindFirstChild(selectedWeapon)
            local realWeapon = WeaponsFolder:FindFirstChild(selectedWeapon)

            if not skinWeapon then
                WindUI:Notification({ Title = "Skin Changer", Desc = "Skin weapon not found in case!", Icon = "x-circle", Time = 3 })
                return
            end
            if not realWeapon then
                WindUI:Notification({ Title = "Skin Changer", Desc = "Real weapon '" .. selectedWeapon .. "' not found in Weapons folder!", Icon = "x-circle", Time = 3 })
                return
            end

            applyOneSkin(skinWeapon, realWeapon)
            WindUI:Notification({
                Title = "Skin Changer",
                Desc = "Applied " .. selectedCase .. " → " .. selectedWeapon .. "!",
                Icon = "check-circle",
                Time = 3,
            })
        end
    end,
})

-- ─── Apply ALL Cases to ALL Weapons ───────────────────────────────────────────
Tab:Divider()

Tab:Button({
    Title = "Apply ALL Cases → ALL Weapons",
    Desc = "Loops every skin case and applies every weapon skin it can match",
    Callback = function()
        local total = 0
        for _, caseName in ipairs(skinCases) do
            total += applyAllInCase(caseName)
        end
        WindUI:Notification({
            Title = "Skin Changer",
            Desc = "Done! Applied skins across " .. #skinCases .. " cases (" .. total .. " total).",
            Icon = "check-circle",
            Time = 5,
        })
    end,
})

-- ─── Refresh ──────────────────────────────────────────────────────────────────
Tab:Button({
    Title = "Refresh Lists",
    Desc = "Re-scans ViewModels for skin cases and weapons",
    Callback = function()
        skinCases = getSkinCases()
        CaseDropdown:Refresh(skinCases)
        if skinCases[1] then
            CaseDropdown:Select(skinCases[1])
        end
        WindUI:Notification({ Title = "Skin Changer", Desc = "Lists refreshed! " .. #skinCases .. " cases found.", Icon = "refresh-cw", Time = 3 })
    end,
})

WindUI:Notification({
    Title = "Skin Changer Loaded",
    Desc = "Press RightShift to toggle. " .. #skinCases .. " skin cases found.",
    Icon = "shirt",
    Time = 5,
})
