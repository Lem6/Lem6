-- Rivals Skin Changer | WindUI Local Script
-- Place inside: Players > LocalPlayer > PlayerScripts

local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ─── References ───────────────────────────────────────────────────────────────
local Players       = game:GetService("Players")
local LocalPlayer   = Players.LocalPlayer
local ViewModels    = LocalPlayer.PlayerScripts.Assets.ViewModels
local WeaponsFolder = ViewModels.Weapons -- only weapons the player owns

-- ─── Get skin cases (everything in ViewModels except Weapons) ─────────────────
local function getSkinCases()
    local cases = {}
    for _, child in ipairs(ViewModels:GetChildren()) do
        if child.Name ~= "Weapons" then
            table.insert(cases, child.Name)
        end
    end
    table.sort(cases)
    return cases
end

-- ─── Get weapons the player OWNS (children of ViewModels.Weapons) ─────────────
local function getOwnedWeapons()
    local owned = {}
    for _, weapon in ipairs(WeaponsFolder:GetChildren()) do
        table.insert(owned, weapon.Name)
    end
    table.sort(owned)
    return owned
end

-- ─── Get skins available in a case FOR weapons the player owns ────────────────
-- i.e. children of the skin case whose name matches something in Weapons
local function getMatchingSkins(caseName)
    local caseFolder = ViewModels:FindFirstChild(caseName)
    if not caseFolder then return {} end
    local owned = getOwnedWeapons()
    local matches = {}
    for _, skinWeapon in ipairs(caseFolder:GetChildren()) do
        if table.find(owned, skinWeapon.Name) then
            table.insert(matches, skinWeapon.Name)
        end
    end
    table.sort(matches)
    return matches
end

-- ─── Core apply ───────────────────────────────────────────────────────────────
-- skin  = ViewModels["Skin Case 2"]["Ban Axe"]
-- weapon = ViewModels.Weapons["Ban Axe"]
local function applyOneSkin(caseName, weaponName)
    local caseFolder = ViewModels:FindFirstChild(caseName)
    if not caseFolder then return false end
    local skinWeapon = caseFolder:FindFirstChild(weaponName)
    local realWeapon = WeaponsFolder:FindFirstChild(weaponName)
    if not skinWeapon or not realWeapon then return false end

    realWeapon:ClearAllChildren()
    for _, v in pairs(skinWeapon:GetChildren()) do
        v:Clone().Parent = realWeapon
    end
    return true
end

-- ─── Build UI ─────────────────────────────────────────────────────────────────
local Window = WindUI:CreateWindow({
    Title = "Rivals Skin Changer",
    Icon = "shirt",
    Author = "by Lem6",
    Folder = "RivalsSkinChanger",
    Size = UDim2.fromOffset(580, 460),
    ToggleKey = Enum.KeyCode.RightShift,
    Transparent = true,
    Theme = "Dark",
    Resizable = true,
})

local Tab = Window:Tab({
    Title = "Skins",
    Icon = "layers",
})

-- ─── State ────────────────────────────────────────────────────────────────────
local selectedCase   = nil
local selectedWeapon = nil
local skinCases      = getSkinCases()

-- ─── Skin Case Dropdown ───────────────────────────────────────────────────────
local WeaponDropdown -- forward declare so CaseDropdown callback can use it

local CaseDropdown = Tab:Dropdown({
    Title = "Skin Case",
    Desc = "Pick a skin case (e.g. Skin Case 2)",
    Values = skinCases,
    Value = skinCases[1] or "None",
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedCase = option
        selectedWeapon = nil

        -- show only weapons YOU OWN that exist in this skin case
        local matches = getMatchingSkins(option)
        if #matches == 0 then
            matches = {"(no owned weapons in this case)"}
        else
            table.insert(matches, 1, "All")
        end

        WeaponDropdown:Refresh(matches)
        WeaponDropdown:Select(matches[1])
        selectedWeapon = matches[1]
    end,
})

if skinCases[1] then
    selectedCase = skinCases[1]
end

-- ─── Weapon Dropdown (owned weapons that have a skin in the selected case) ─────
local initialMatches = getMatchingSkins(selectedCase or "")
if #initialMatches == 0 then
    initialMatches = {"(no owned weapons in this case)"}
else
    table.insert(initialMatches, 1, "All")
end

WeaponDropdown = Tab:Dropdown({
    Title = "Your Weapons",
    Desc = "Only shows weapons you own that have a skin in the selected case",
    Values = initialMatches,
    Value = initialMatches[1],
    Multi = false,
    AllowNone = false,
    Callback = function(option)
        selectedWeapon = option
    end,
})
selectedWeapon = initialMatches[1]

-- ─── Apply Button ─────────────────────────────────────────────────────────────
Tab:Button({
    Title = "Apply Skin",
    Desc = "Applies the skin from the selected case to your weapon(s)",
    Callback = function()
        if not selectedCase or not selectedWeapon then
            WindUI:Notification({ Title = "Skin Changer", Desc = "Select a case and weapon first!", Icon = "alert-circle", Time = 3 })
            return
        end

        if selectedWeapon == "All" then
            local matches = getMatchingSkins(selectedCase)
            local count = 0
            for _, wName in ipairs(matches) do
                if applyOneSkin(selectedCase, wName) then
                    count += 1
                end
            end
            WindUI:Notification({
                Title = "Skin Changer",
                Desc = "Applied " .. selectedCase .. " to " .. count .. " weapon(s)!",
                Icon = "check-circle",
                Time = 4,
            })
        else
            if applyOneSkin(selectedCase, selectedWeapon) then
                WindUI:Notification({
                    Title = "Skin Changer",
                    Desc = "Applied " .. selectedCase .. " → " .. selectedWeapon,
                    Icon = "check-circle",
                    Time = 3,
                })
            else
                WindUI:Notification({
                    Title = "Skin Changer",
                    Desc = "Failed — weapon not found in case or Weapons folder.",
                    Icon = "x-circle",
                    Time = 3,
                })
            end
        end
    end,
})

-- ─── Apply ALL cases to ALL owned weapons ─────────────────────────────────────
Tab:Divider()

Tab:Button({
    Title = "Apply ALL Cases → ALL Your Weapons",
    Desc = "Every skin case, every weapon you own — applied all at once",
    Callback = function()
        local total = 0
        for _, caseName in ipairs(skinCases) do
            local matches = getMatchingSkins(caseName)
            for _, wName in ipairs(matches) do
                if applyOneSkin(caseName, wName) then
                    total += 1
                end
            end
        end
        WindUI:Notification({
            Title = "Skin Changer",
            Desc = "Done! " .. total .. " skin(s) applied across all cases.",
            Icon = "check-circle",
            Time = 5,
        })
    end,
})

-- ─── Refresh ──────────────────────────────────────────────────────────────────
Tab:Button({
    Title = "Refresh",
    Desc = "Re-scans ViewModels and your owned weapons",
    Callback = function()
        skinCases = getSkinCases()
        CaseDropdown:Refresh(skinCases)
        if skinCases[1] then
            CaseDropdown:Select(skinCases[1])
        end
        WindUI:Notification({ Title = "Skin Changer", Desc = "Refreshed! " .. #skinCases .. " cases found.", Icon = "refresh-cw", Time = 3 })
    end,
})

-- ─── Owned weapons info ───────────────────────────────────────────────────────
local owned = getOwnedWeapons()
WindUI:Notification({
    Title = "Skin Changer Loaded",
    Desc = "RightShift to toggle. " .. #owned .. " weapon(s) owned, " .. #skinCases .. " skin case(s) found.",
    Icon = "shirt",
    Time = 6,
})
